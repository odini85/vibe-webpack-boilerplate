{
  "name": "webpack-boilerplate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "serve:dev": "cross-env APP_ENV=dev pnpm exec webpack serve --config webpack.dev.js",
    "serve:mock": "cross-env APP_ENV=dev USE_MOCK=true pnpm exec webpack serve --config webpack.dev.js",
    "serve:qa": "cross-env APP_ENV=qa pnpm exec webpack serve --config webpack.dev.js",
    "serve:live": "cross-env APP_ENV=live pnpm exec webpack serve --config webpack.dev.js",
    "build:dev": "cross-env APP_ENV=dev pnpm exec webpack --config webpack.prod.js",
    "build:qa": "cross-env APP_ENV=qa pnpm exec webpack --config webpack.prod.js",
    "build:live": "cross-env APP_ENV=live pnpm exec webpack --config webpack.prod.js",
    "preview": "node scripts/serve-dist.mjs",
    "build:preview": "pnpm build:live && pnpm preview",
    "typecheck": "pnpm exec tsc --noEmit",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "pnpm exec prettier --write .",
    "test": "pnpm exec vitest run",
    "test:watch": "pnpm exec vitest"
  },
  "engines": {
    "node": ">=18.17"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@types/node": "^22.7.4",
    "@types/webpack-env": "^1.18.5",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitest/coverage-v8": "^2.1.3",
    "babel-loader": "^10.0.0",
    "clean-webpack-plugin": "^4.0.0",
    "core-js": "^3.48.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "html-webpack-plugin": "^5.6.3",
    "jsdom": "^28.1.0",
    "mini-css-extract-plugin": "^2.9.1",
    "prettier": "^3.3.3",
    "sass": "^1.81.0",
    "sass-loader": "^16.0.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^2.1.3",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0",
    "webpack-merge": "^6.0.1"
  }
}
